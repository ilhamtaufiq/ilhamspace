# App
ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-string

# SQLite (local dev: ./data/ilhamspace.db | Docker/Coolify: /data/ilhamspace.db)
DATABASE_PATH=./data/ilhamspace.db

# Docker / Coolify (optional)
# BODY_SIZE_LIMIT=15M

# Single admin (local: pnpm db:seed | Docker: set below and redeploy)
ADMIN_EMAIL=you@example.com
ADMIN_NAME=Your Name
# Coolify/Docker: prefer plain password (hashed on each container start):
# ADMIN_PASSWORD=your-secure-password
#
# Bcrypt hash (local dev). Must be quoted in Docker — $ breaks env parsing:
# pnpm db:hash-password yourpassword
ADMIN_PASSWORD_HASH=

